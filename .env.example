# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# If your password contains @, encode it as %40
# Example: password@123 → password%40123
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/atelier04"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API Authentication ───────────────────────────────────────────────────────
# Bearer token required on all API requests — minimum 32 characters
API_KEY="your-secret-api-key-minimum-32-characters-long"

# ─── eSeal Signing ───────────────────────────────────────────────────────────
# Qualified eSeal .p12 file for signing EDCI XML (provided by client)
# Leave empty to use mock signing during development
ESEAL_P12_PATH=""
ESEAL_P12_PASSWORD=""

# ─── Europass ────────────────────────────────────────────────────────────────
EUROPASS_WALLET_URL="https://europass.europa.eu/edci-wallet/api/v1/wallets/email"

# ─── URLs ────────────────────────────────────────────────────────────────────
# Public base URL of this server (used for badge file URLs)
BASE_URL="https://your-domain.com"

# Base URL for credential verification pages on atelier04.at
ATELIER04_VERIFICATION_BASE="https://atelier04.at/credentials"
