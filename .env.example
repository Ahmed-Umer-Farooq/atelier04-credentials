# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# If your password contains @, encode it as %40
# Example: password@123 → password%40123
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/atelier04"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API Authentication ───────────────────────────────────────────────────────
# Bearer token required on all API requests — minimum 32 characters
API_KEY="your-secret-api-key-minimum-32-characters-long"

# ─── URLs ────────────────────────────────────────────────────────────────────
# Public base URL of this server (used for badge file URLs)
BASE_URL="https://your-domain.com"

# Base URL for credential verification pages
ATELIER04_VERIFICATION_BASE="https://atelier04.at/credentials"

# ─── Europass ────────────────────────────────────────────────────────────────
EUROPASS_WALLET_URL="https://europass.europa.eu/edci-wallet/api/v1/wallets/email"

# ─── A-Trust eSeal ───────────────────────────────────────────────────────────
# Qualified eSeal certificate (.p12) for signing EDCI XML and JSON-LD credentials
# Switch to production values when going live:
#   ATRUST_API_URL=https://seal.a-trust.at/SealQualified/v1
#   ATRUST_P12_PATH=./certs/authentication_certificate.p12
#   ATRUST_P12_PASSWORD=<real password>
ATRUST_API_URL="https://test.seal.a-trust.at/SealQualified/v1"
ATRUST_P12_PATH="./atelier04.p12"
ATRUST_P12_PASSWORD="your-p12-password"
